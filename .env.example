# Core settings used by the current application

# Async SQLAlchemy connection for local development
DATABASE_URL=postgresql+asyncpg://aurellis_user:aurellis_password@localhost:5432/aurellis_scraping_dev

# Optional for MVP local runs.
# If empty, the system falls back to heuristic extraction when AI is unavailable.
DEEPSEEK_API_KEY=


# Planned settings for upcoming hardening work
# These are documented here so the team has a single reference point,
# but they are not consumed by the current code yet.

# Explicit demo mode for mock/fallback behavior in URL discovery.
# When false, search discovery fails explicitly instead of injecting hardcoded URLs.
DEMO_MODE=false

# Toggle TLS verification only for controlled debugging scenarios
HTTP_VERIFY_TLS=true

# Retry policy for transient HTTP/network failures
HTTP_MAX_RETRIES=2
HTTP_BACKOFF_BASE_SECONDS=1.0

# Internal token reserved for future server-to-server protection
INTERNAL_API_TOKEN=change-me-before-production
